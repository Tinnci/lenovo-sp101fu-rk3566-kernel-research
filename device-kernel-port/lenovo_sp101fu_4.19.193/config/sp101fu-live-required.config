# Lenovo SP101FU / Louvre / RK3566 E Ink live-kernel required symbols.
# Source: /proc/config.gz from the device, build SP101FU_S001336_240712_ROW.
#
# This fragment intentionally includes vendor symbols that are not present in
# the public Rockchip 4.19 tree. If merge_config.sh drops a symbol, that means
# the corresponding Kconfig/source driver is missing and must be imported or
# replaced, not merely enabled.

# Core identity / boot behavior
CONFIG_ARCH_ROCKCHIP=y
CONFIG_ARM64=y
CONFIG_PREEMPT=y
CONFIG_HZ_300=y
CONFIG_HZ=300
CONFIG_MODULES=y
CONFIG_BLK_DEV_INITRD=y
CONFIG_IKCONFIG=y
CONFIG_IKCONFIG_PROC=y
CONFIG_CMDLINE=""
CONFIG_CMDLINE_PARTITION=y

# CPU, memory, performance and devfreq
CONFIG_CPU_IDLE=y
CONFIG_CPU_IDLE_GOV_MENU=y
CONFIG_CPU_FREQ=y
CONFIG_CPU_FREQ_STAT=y
CONFIG_CPU_FREQ_TIMES=y
CONFIG_CPU_FREQ_DEFAULT_GOV_INTERACTIVE=y
CONFIG_CPU_FREQ_GOV_PERFORMANCE=y
CONFIG_CPU_FREQ_GOV_POWERSAVE=y
CONFIG_CPU_FREQ_GOV_USERSPACE=y
CONFIG_CPU_FREQ_GOV_ONDEMAND=y
CONFIG_CPU_FREQ_GOV_CONSERVATIVE=y
CONFIG_CPU_FREQ_GOV_SCHEDUTIL=y
CONFIG_CPU_FREQ_GOV_INTERACTIVE=y
CONFIG_PM_DEVFREQ=y
CONFIG_DEVFREQ_GOV_SIMPLE_ONDEMAND=y
CONFIG_DEVFREQ_GOV_PERFORMANCE=y
CONFIG_DEVFREQ_GOV_POWERSAVE=y
CONFIG_DEVFREQ_GOV_USERSPACE=y
CONFIG_ARM_ROCKCHIP_BUS_DEVFREQ=y
CONFIG_ARM_ROCKCHIP_DMC_DEVFREQ=y
CONFIG_ARM_ROCKCHIP_DMC_DEBUG=y
CONFIG_DEVFREQ_EVENT_ROCKCHIP_DFI=y
CONFIG_DEVFREQ_EVENT_ROCKCHIP_NOCP=y

# Wi-Fi / Bluetooth
CONFIG_WLAN=y
CONFIG_BCMDHD=y
CONFIG_BCMDHD_FW_PATH="/vendor/etc/firmware/fw_bcmdhd.bin"
CONFIG_BCMDHD_NVRAM_PATH="/vendor/etc/firmware/nvram.txt"
CONFIG_BT=y
CONFIG_BT_BREDR=y
CONFIG_BT_RFCOMM=y
CONFIG_BT_RFCOMM_TTY=y
CONFIG_BT_BNEP=y
CONFIG_BT_HIDP=y
CONFIG_BT_LE=y
CONFIG_BT_HCIUART=y
CONFIG_BT_HCIUART_H4=y

# Power/audio PMIC
CONFIG_BATTERY_RK817=y
CONFIG_CHARGER_RK817=y
CONFIG_SND_SOC_RK817=y
CONFIG_SND_SOC_BT_SCO=y

# GPU/display/video
CONFIG_MALI_MEMORY_GROUP_MANAGER=y
CONFIG_DMA_SHARED_BUFFER=y
# live FDT: gpu@fde60000 compatible = "arm,mali-bifrost"
# CONFIG_MALI_MIDGARD is not set
CONFIG_MALI_BIFROST_FOR_ANDROID=y
CONFIG_MALI_BIFROST=y
# CONFIG_MALI400 is not set
# CONFIG_POWERVR_ROGUE_N is not set
CONFIG_MALI_BIFROST_DEVFREQ=y
CONFIG_MALI_PLATFORM_NAME="rk"
CONFIG_MALI_REAL_HW=y
CONFIG_MALI_BIFROST_ENABLE_TRACE=y
CONFIG_MALI_BIFROST_SYSTEM_TRACE=y
CONFIG_ROCKCHIP_MPP_PROC_FS=y

# No camera hardware is present on this e-reader. Keep Rockchip MPP/video codec
# support, but do not build camera capture, UVC, CIF, or ISP drivers.
# CONFIG_MEDIA_CAMERA_SUPPORT is not set
# CONFIG_MEDIA_USB_SUPPORT is not set
# CONFIG_USB_VIDEO_CLASS is not set
# CONFIG_V4L_PLATFORM_DRIVERS is not set
# CONFIG_VIDEO_ROCKCHIP_CIF is not set
# CONFIG_VIDEO_ROCKCHIP_ISP1 is not set
# CONFIG_VIDEO_ROCKCHIP_ISP is not set
# CONFIG_VIDEO_RK628_CSI is not set
# CONFIG_LEDS_RGB13H is not set

# E Ink vendor stack: missing from public Rockchip tree, required by live DTB.
CONFIG_HTFY_EBC=y
CONFIG_PMIC_EBC_TPS65185=y
CONFIG_PMIC_EBC_SY7636A=y
# CONFIG_HTFY_DUMP is not set
# CONFIG_HTFY_DEBUG is not set

# Touch / pen / input vendor stack: missing or incomplete in public tree.
CONFIG_TOUCHSCREEN_GOODIX_GTX8=y
# CONFIG_TOUCHSCREEN_HUION_PANELS is not set
# CONFIG_TOUCHSCREEN_HDX8801 is not set
# GSL touch controllers are enabled in vendor config but absent from live FDT.
# CONFIG_TOUCHSCREEN_GSLX6801 is not set
# CONFIG_TOUCHSCREEN_GSLX680_PAD is not set
# CONFIG_TOUCHSCREEN_GSLX680_VR is not set
# CONFIG_TOUCHSCREEN_GSL3673 is not set
# CONFIG_TOUCHSCREEN_GSL3673_800X1280 is not set
# CONFIG_TOUCHSCREEN_GSL3676 is not set
CONFIG_HID_WACOM=y
# CONFIG_I2C_HID_WACOM_9013 is not set
CONFIG_I2C_HID_WACOM_10S12MI=y

# Sensors and Type-C-side board peripherals: mostly missing from public tree.
CONFIG_GS_MXC6655XA=y
CONFIG_LS_STK3x1x=y
CONFIG_LS_LTR578=y
CONFIG_AW9610X_SAR=y
CONFIG_HS_WH2506D=y

# No fingerprint hardware is present; the live config entry is a vendor/reference
# residue and should stay disabled for the SP101FU-targeted build.
# CONFIG_INPUT_FINGERPRINT is not set
# CONFIG_FOCALTECH_FINGERPRINT is not set
# CONFIG_GOODIX_FINGERPRINT is not set
